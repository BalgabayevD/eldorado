# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# App URL (your Render domain, e.g. https://eldorado.onrender.com)
ORIGIN="https://your-app.onrender.com"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME="eldorado_crypto_bot"

# CoinMarketCap API
COINMARKETCAP_API_KEY=""

# Resend (email)
RESEND_API_KEY=""

# Cron job protection
CRON_SECRET=""
